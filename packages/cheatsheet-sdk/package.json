{
  "name": "@cheatsheet-studio/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Headless SDK + CLI for agent-authored CheatSheet Studio sheets (does not load the React UI)",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "cheatsheet": "./bin/cheatsheet.mjs"
  },
  "scripts": {
    "cli": "tsx src/cli.ts",
    "test": "vitest run --config ../../vitest.config.ts src"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "firebase-admin": ">=12"
  },
  "peerDependenciesMeta": {
    "firebase-admin": {
      "optional": true
    }
  }
}
