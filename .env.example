# Firebase Web App config (Project settings → Your apps)
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# This project REQUIRES Firebase setup for Auth, Firestore, Storage, and Hosting.

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# --- Local emulators (Auth + Firestore + Storage) ---
# Prefer package scripts: npm run emulators / npm run test:e2e:emulators
# When true, demo config is used and SDKs connect to localhost emulators.
# VITE_USE_FIREBASE_EMULATORS=true
# VITE_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# VITE_FIREBASE_FIRESTORE_EMULATOR_HOST=127.0.0.1
# VITE_FIREBASE_FIRESTORE_EMULATOR_PORT=8080

# =============================================================================
# Ollama — AI Auto layout (left sidebar)
# Docs: https://docs.ollama.com/cloud
# Keys: https://ollama.com/settings/keys
#
# IMPORTANT: use OLLAMA_API_KEY (no VITE_ prefix) so the key is only read by
# the Vite dev server proxy and is NEVER shipped to the browser bundle.
# The app calls same-origin /ollama-proxy → avoids Chrome CORS.
# =============================================================================

# Required for Ollama Cloud API (Bearer token)
OLLAMA_API_KEY=your_ollama_api_key_here

# cloud = https://ollama.com (default when OLLAMA_API_KEY is set)
# local = http://127.0.0.1:11434 (local ollama serve; key optional)
OLLAMA_MODE=cloud

# Optional override of the proxy target host
# OLLAMA_HOST=https://ollama.com
# OLLAMA_HOST=http://127.0.0.1:11434

# Browser-visible settings only (safe to prefix with VITE_)
# Cloud API model names usually omit the "-cloud" suffix:
VITE_OLLAMA_MODEL=gemma4:31b
# Force browser base (default /ollama-proxy — leave unset)
# VITE_OLLAMA_BASE_URL=/ollama-proxy
