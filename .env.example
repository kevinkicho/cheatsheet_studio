# Firebase Web App config (Project settings → Your apps)
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# This project REQUIRES Firebase setup for Auth, Firestore, Storage, and Hosting.

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# --- Local emulators (Auth + Firestore + Storage) ---
# Prefer package scripts: npm run emulators / npm run test:e2e:emulators
# When true, demo config is used and SDKs connect to localhost emulators.
# VITE_USE_FIREBASE_EMULATORS=true
# VITE_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# VITE_FIREBASE_FIRESTORE_EMULATOR_HOST=127.0.0.1
# VITE_FIREBASE_FIRESTORE_EMULATOR_PORT=8080

# --- Local Ollama (AI Auto layout in left sidebar) ---
# Default: http://127.0.0.1:11434 · model gemma4:31b-cloud
# VITE_OLLAMA_BASE_URL=http://127.0.0.1:11434
# VITE_OLLAMA_MODEL=gemma4:31b-cloud
# Use Vite proxy if browser CORS blocks Ollama:
# VITE_OLLAMA_USE_PROXY=true
